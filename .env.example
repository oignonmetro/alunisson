# ─────────────────────────────────────────────────────────────
# Configuration Firebase — copiez ce fichier en `.env` et
# remplissez avec les valeurs de VOTRE projet Firebase.
# (Console Firebase → Paramètres du projet → Vos applications → SDK Web)
# ─────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Mettre à 1 pour utiliser l'émulateur Firebase local (développement/test
# sans compte). Utilisez plutôt `npm run dev:emulator` qui le fait pour vous.
# VITE_USE_EMULATOR=0
